{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck:libs && BASE_PATH=/ pnpm --filter @workspace/hotel-booking run build",
  "outputDirectory": "artifacts/hotel-booking/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
